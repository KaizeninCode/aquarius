{
  "expo": {
    "name": "Aquarius Driver",
    "slug": "aquarius-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-1024-1024.png",
    "scheme": "driver",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "updates": {
      "url":"https://u.expo.dev/b5917053-1ab8-49c4-8b09-2f35d4896a26"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aquarius.driver",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#00a63e",
        "foregroundImage": "./assets/icon-1024-1024.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.aquarius.driver",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-4096-4096.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#00a63e",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-firebase/app"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b5917053-1ab8-49c4-8b09-2f35d4896a26"
      }
    }
  }
}
